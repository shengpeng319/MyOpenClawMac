    {
      "id": "f9aaf978-5d2d-4296-8854-6db0662f46ae",
      "name": "每日进化报告",
      "enabled": true,
      "createdAtMs": 1772635670112,
      "updatedAtMs": 1773669722339,
      "schedule": {
        "kind": "cron",
        "expr": "0 22 * * *",
        "tz": "Asia/Shanghai"
      },
      "sessionTarget": "isolated",
      "wakeMode": "now",
      "payload": {
        "kind": "agentTurn",
        "message": "# 📊 每日进化报告\n\n请执行以下任务：\n1. 回顾今天的会话历史\n2. 提取关键要点\n3. 分析学会了什么、犯了什么错、怎么解决的\n4. 形成每日进化报告，提议可以固化的技能\n5. 发送报告给我\n6. 运行 ~/bin/backup-openclaw.sh 备份配置到 GitHub"
      },
      "delivery": {
        "mode": "announce",
        "channel": "feishu",
        "to": "oc_49bd38a7e7152bafbb125392b40e2939"
      },
      "state": {
        "nextRunAtMs": 1773756000000,
        "lastRunAtMs": 1773669600010,
        "lastRunStatus": "ok",
        "lastStatus": "ok",
        "lastDurationMs": 122329,
        "lastDelivered": true,
        "lastDeliveryStatus": "delivered",
        "consecutiveErrors": 0
      }
    },
