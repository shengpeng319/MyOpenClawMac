    {
      "id": "042e920d-1dd9-48e3-809b-a39cd1f37998",
      "agentId": "educationexpert",
      "name": "每日课程提醒",
      "enabled": true,
      "createdAtMs": 1773468718510,
      "updatedAtMs": 1773961523185,
      "schedule": {
        "kind": "cron",
        "expr": "5 7 * * *"
      },
      "sessionTarget": "isolated",
      "wakeMode": "now",
      "payload": {
        "kind": "agentTurn",
        "message": "你是教育专家 Diana。请完成以下任务：\n\n1. 读取 USER.md 中的课程表，根据今天的星期几，找出两个孩子的课程，列出每个课程的出发时间\n2. 根据课程安排给出关怀提醒（如：连续课程提醒提前点餐等）\n\n生成简洁的早间课程提醒消息发出即可。\n\n然后，你需要为每个课程创建一次性用完即删的子task：\n- 对于每个课程，计算其出发时间（减去20分钟就是提醒时间）\n- 使用 --at 参数创建一次性任务，在提醒时间触发\n- 使用 --delete-after-run 参数确保task执行后自动删除\n- 命名格式：\"课程提醒-课程名称-时间\"\n\n出发时间格式是 HH:MM（24小时制），比如下午5:10 就是 17:10。提醒时间 = 出发时间 - 20分钟。\n\n创建子task的命令格式示例（注意使用 --at 而不是 --cron）：\nopenclaw cron add --name \"课程提醒-游泳-17:10\" --at \"2026-03-14T16:50:00+08:00\" --message \"提醒：蛋蛋的游泳课还有20分钟就要出发了，出发时间是17:10，课程是5:30-7:00，地点在莲花体育中心。\" --to \"oc_49bd38a7e7152bafbb125392b40e2939\" --expect-final --delete-after-run --timeout-seconds 30\n\n注意：日期格式是 YYYY-MM-DDTHH:MM:00+08:00",
        "timeoutSeconds": 300
      },
      "delivery": {
        "mode": "announce",
        "channel": "last",
        "to": "oc_49bd38a7e7152bafbb125392b40e2939"
      },
      "state": {
        "nextRunAtMs": 1774047900000,
        "lastRunAtMs": 1773961500009,
        "lastRunStatus": "ok",
        "lastStatus": "ok",
        "lastDurationMs": 23176,
        "lastDeliveryStatus": "delivered",
        "consecutiveErrors": 0,
        "lastDelivered": true
      }
    },
